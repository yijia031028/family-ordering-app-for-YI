{
  "version": 2,
  "builds": [
    {
      "src": "backend/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "admin-system/backend/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "admin-system/frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/main.py"
    },
    {
      "source": "/admin-api/(.*)",
      "destination": "admin-system/backend/main.py"
    },
    {
      "source": "/admin/(.*)",
      "destination": "admin-system/frontend/$1"
    },
    {
      "source": "/admin",
      "destination": "admin-system/frontend/index.html"
    },
    {
      "source": "/supabase-img/(.*)",
      "destination": "https://apsfgjcqkikszpxcysiv.supabase.co/storage/v1/object/public/dishes/$1"
    },
    {
      "source": "/google-img/(.*)",
      "destination": "https://lh3.googleusercontent.com/$1"
    },
    {
      "source": "/wiki-img/(.*)",
      "destination": "https://upload.wikimedia.org/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/google-img/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, s-maxage=604800, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/wiki-img/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, s-maxage=604800, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/supabase-img/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, s-maxage=604800, stale-while-revalidate=86400" }
      ]
    }
  ]
}
