rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'name', 'avatar', 'familyName', 'role', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 50 &&
             data.avatar is string && data.avatar.size() < 500 &&
             data.familyName is string && data.familyName.size() > 0 && data.familyName.size() < 100 &&
             data.createdAt is timestamp;
    }
    
    function isValidOrder(data) {
      return hasOnlyAllowedFields(['userId', 'userName', 'userAvatar', 'familyName', 'dishId', 'dishName', 'dishImage', 'createdAt']) &&
             data.userId is string &&
             data.userName is string && data.userName.size() < 50 &&
             data.userAvatar is string && data.userAvatar.size() < 500 &&
             data.familyName is string && data.familyName.size() < 100 &&
             data.dishId is string && data.dishId.size() < 100 &&
             data.dishName is string && data.dishName.size() < 100 &&
             data.dishImage is string && data.dishImage.size() < 500 &&
             data.createdAt is timestamp;
    }
    
    function isValidFamily(data) {
      return hasOnlyAllowedFields(['name', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{userId} {
      // Public access requested by user for demo purposes
      allow read: if true;
      allow create: if isValidUser(request.resource.data);
      allow update: if isValidUser(request.resource.data);
      allow delete: if true;
    }
    
    match /families/{familyName} {
      // Public access requested by user for demo purposes
      allow read: if true;
      allow create: if isValidFamily(request.resource.data);
      allow update: if isValidFamily(request.resource.data);
      allow delete: if true;
    }
    
    match /orders/{orderId} {
      // Public access requested by user for demo purposes
      allow read: if true;
      allow create: if isValidOrder(request.resource.data);
      allow update: if isValidOrder(request.resource.data);
      allow delete: if true;
    }
  }
}
